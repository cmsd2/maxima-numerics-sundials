75,-17.037769376181487,-17.269355208554714,-17.5019286137739,-17.73548959183902,-17.97003814275009,-18.205574266507085,-18.442097963110037,-18.679609232558924,-18.918108074853755,-19.157594489994516,-19.398068477981234,-19.639530038813888,-19.881979172492485,-20.125415879017012,-20.369840158387497,-20.61525201060391,-20.861651435666275,-21.109038433574568,-21.357413004328812,-21.606775147928992,-21.857124864375123,-22.108462153667183,-22.360787015805194,-22.61409945078914,-22.868399458619038,-23.123687039294865,-23.37996219281664,-23.637224919184348,-23.895475218398005,-24.154713090457598,-24.41493853536314,-24.676151553114615,-24.938352143712045,-25.201540307155398,-25.465716043444708,-25.73087935257994,-25.99703023456113,-26.264168689388256,-26.532294717061333,-26.80140831758034,-27.071509490945296,-27.342598237156196,-27.614674556213018,-27.887738448115805,-28.16178991286452,-28.436828950459173,-28.71285556089976,-28.989869744186315,-29.267871500318797,-29.546860829297216,-29.82683773112158,-30.10780220579189,-30.38975425330814,-30.672693873670326,-30.95662106687844,-31.24153583293252,-31.527438171832543,-31.814328083578488,-32.102205568170376,-32.39107062560822,-32.680923255892004,-32.971763459021716,-33.26359123499737,-33.556406583818976,-33.850209505486525,-34.145],\"type\":\"scatter\",\"mode\":\"lines\",\"line\":{\"color\":\"#2563eb\",\"width\":2},\"name\":\"h(t)\"},{\"x\":[1.4278431229271473],\"y\":[-1.1652900866465643e-12],\"type\":\"scatter\",\"mode\":\"markers\",\"marker\":{\"color\":\"#dc2626\",\"size\":8},\"name\":\"impact\"}],\"layout\":{\"title\":{\"text\":\"Bouncing Ball (single bounce)\"},\"showlegend\":true,\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"t (s)\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"h (m)\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
            ]
