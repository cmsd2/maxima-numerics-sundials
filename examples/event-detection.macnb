.655009451781023,1.5261311953856804,1.396265366144398,1.2654119640571722,1.1335709891240064,1.000742441344899,0.8669263207198501,0.7321226272488595,0.596331360931929,0.45955252176905326,0.32178610976024125,0.18303212490548404,0.04329056720479052,-0.09743856334185175,-0.23915526673442855,-0.38185954297295055,-0.5255513920574106,-0.6702308139878177,-0.8158978087641593,-0.9625523763864479,-1.1101945168546727,-1.2588242301688446,-1.408441516328951,-1.5590463753350061,-1.7106388071869958,-1.8632188118849307,-2.0167863894288036,-2.1713415398186235,-2.326884263054378,-2.4834145591360794,-2.640932428063717,-2.7994378698373037,-2.958930884456823,-3.119411471922291,-3.2808796322336917,-3.443335365391043,-3.606778671394328,-3.7712095502435607,-3.936628001938728,-4.103034026479845,-4.270427623866896,-4.438808794099893,-4.608177537178826,-4.778533853103708,-4.9498777418745235,-5.122209203491291,-5.295528237953992,-5.4698348452626355,-5.64512902541722,-5.821410778417746,-5.998680104264213,-6.17693700295662,-6.356181474494971,-6.536413518879261,-6.717633136109494,-6.899840326185666,-7.083035089107781,-7.267217424875837,-7.452387333489835,-7.638544814949773,-7.825689869255655,-8.013822496407476,-8.202942696405238,-8.393050469248942,-8.584145814938587,-8.776228733474174,-8.969299224855703,-9.163357289083173,-9.358402926156582,-9.554436136075935,-9.751456918841228,-9.949465274452466,-10.148461202909639,-10.348444704212751,-10.549415778361814,-10.751374425356818,-10.954320645197756,-11.158254437884633,-11.363175803417462,-11.569084741796246,-11.775981253020973,-11.983865337091629,-12.192736994008214,-12.402596223770729,-12.613443026379286,-12.82527740183366,-13.038099350133962,-13.251908871280193,-13.466705965272581,-13.682490632110671,-13.89926287179469,-14.117022684324866,-14.335770069700857,-14.555505027922777,-14.77622755899074,-14.99793766290452,-15.220635339664227,-15.444320589269978,-15.668993411721658,-15.894653807019267,-16.121301775162806,-16.348937316152274,-16.57756042998767,-16.807171116668997,-17.037769376196366,-17.269355208569664,-17.501928613788778,-17.73548959185382,-17.97003814276502,-18.20557426652192,-18.442097963124866,-18.67960923257374,-18.91810807486854,-19.157594490009387,-19.39806847799605,-19.639530038828752,-19.881979172507386,-20.12541587903172,-20.36984015840244,-20.615252010618747,-20.861651435681097,-21.109038433589376,-21.357413004343698,-21.606775147943836,-21.857124864390016,-22.108462153682012,-22.36078701582005,-22.614099450803906,-22.868399458633917,-23.123687039309743,-23.3799621928315,-23.637224919199184,-23.895475218412912,-24.154713090472455,-24.414938535377928,-24.676151553129557,-24.93835214372689,-25.201540307170262,-25.465716043459565,-25.730879352594798,-25.99703023457596,-26.26416868940305,-26.532294717076184,-26.801408317595133,-27.071509490960125,-27.342598237171046,-27.614674556227783,-27.887738448130676,-28.16178991287927,-28.436828950474023,-28.71285556091459,-28.9898697442012,-29.267871500333626,-29.546860829312095,-29.82683773113638,-30.107802205806706,-30.389754253322963,-30.67269387368526,-30.956621066893263,-31.241535832947307,-31.527438171847393,-31.814328083593296,-32.10220556818524,-32.391070625623,-32.680923255906805,-32.97176345903665,-33.2635912350122,-33.556406583833905,-33.85020950550131,-34.14500000001476],\"type\":\"scatter\",\"mode\":\"lines\",\"line\":{\"color\":\"#2563eb\",\"width\":2},\"name\":\"h(t)\"},{\"x\":[1.4278431229260498],\"y\":[-6.039613253960852e-13],\"type\":\"scatter\",\"mode\":\"markers\",\"marker\":{\"color\":\"#dc2626\",\"size\":8},\"name\":\"impact\"}],\"layout\":{\"title\":{\"text\":\"Bouncing Ball (single bounce)\"},\"showlegend\":true,\"width\":700,\"height\":450,\"plot_bgcolor\":\"white\",\"paper_bgcolor\":\"white\",\"xaxis\":{\"title\":{\"text\":\"t (s)\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1},\"yaxis\":{\"title\":{\"text\":\"h (m)\"},\"showgrid\":true,\"gridcolor\":\"#ddd\",\"linecolor\":\"#ddd\",\"linewidth\":1,\"zerolinecolor\":\"black\",\"zerolinewidth\":1}}}"
            ]
